# Clerk (frontend) — copy from Clerk dashboard
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxx

# Convex deployment URL — printed after `npx convex dev`
VITE_CONVEX_URL=https://your-deployment.convex.cloud

# Convex server-side: Clerk JWT issuer domain (no trailing slash)
# Found in Clerk dashboard → JWT Templates → "convex" template
CLERK_JWT_ISSUER_DOMAIN=https://your-app.clerk.accounts.dev
